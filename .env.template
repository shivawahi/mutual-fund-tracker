# ════════════════════════════════════════════════════════════════
#  Finance First Services — Mutual Fund Tracker
#  Environment Variables
#
#  HOW TO USE:
#    1. Copy this file and rename the copy to just:  .env
#    2. Fill in YOUR real values below
#    3. NEVER share .env or commit it to Git
# ════════════════════════════════════════════════════════════════


# ── Login credentials for Finance First Services ─────────────────
# https://portfolio.financefirstservices.com/Login/login/client-login

INVESTMENT_USERNAME=your_username_here
INVESTMENT_PASSWORD=your_password_here


# ── Google Sheets ─────────────────────────────────────────────────
# Find your Sheet ID in the URL:
#   https://docs.google.com/spreadsheets/d/ ► COPY_THIS_PART ◄ /edit

GOOGLE_SHEETS_ID=paste_your_sheet_id_here

# Full path to the service account JSON you downloaded from Google Cloud
# Windows example:  C:\Users\YourName\credentials\service_account.json
# Mac/Linux example: /Users/yourname/credentials/service_account.json

SERVICE_ACCOUNT_FILE=C:\path\to\your\service_account.json


# ── Optional: CSS selectors (filled after running step1_find_selectors.py) ───
# Leave blank to use the auto-detect logic in tracker.py.
# Only set these if auto-detect fails.

SELECTOR_INVESTED=
SELECTOR_CURRENT_VALUE=
